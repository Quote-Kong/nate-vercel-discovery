    "@radix-ui/react-slider": "^1.3.6",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/blob": "^2.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "mysql2": "^3.22.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "resend": "^6.12.3",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
